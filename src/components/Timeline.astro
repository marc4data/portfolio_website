---
import careerData from '../data/career.json';
---

<section id="timeline" class="bg-brand-light py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-14 text-center">
      <p class="text-brand-teal text-sm font-semibold tracking-widest uppercase mb-2">Career</p>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy">The Track Record</h2>
      <p class="mt-3 text-brand-slate text-base md:text-lg max-w-xl mx-auto">
        Every role, the same pattern — arrive, assess, build, deliver.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-0.5 bg-brand-teal/30 -translate-x-1/2 hidden md:block"></div>

      <div class="flex flex-col gap-10">
        {careerData.map((role, index) => (
          <div class={`relative flex flex-col md:flex-row gap-6 md:gap-10 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>

            <!-- Timeline dot (desktop) -->
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-6 w-4 h-4 rounded-full bg-brand-teal border-4 border-white shadow z-10"></div>

            <!-- Spacer (desktop alternating layout) -->
            <div class="hidden md:block md:w-1/2"></div>

            <!-- Card -->
            <div class="md:w-1/2 bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
              <!-- Company + dates header -->
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="text-lg font-bold text-brand-navy leading-tight">{role.company}</h3>
                  <p class="text-brand-teal font-semibold text-sm mt-0.5">{role.title}</p>
                </div>
                <div class="text-right flex-shrink-0">
                  <span class="inline-block bg-brand-navy/5 text-brand-navy text-xs font-semibold px-3 py-1 rounded-full">
                    {role.start} – {role.end}
                  </span>
                  <p class="text-xs text-brand-slate mt-1">{role.location}</p>
                </div>
              </div>

              <!-- Summary -->
              <p class="text-brand-slate text-sm leading-relaxed mb-4 italic border-l-2 border-brand-teal/30 pl-3">
                {role.summary}
              </p>

              <!-- Highlights -->
              <ul class="space-y-2">
                {role.highlights.map(highlight => (
                  <li class="flex items-start gap-2 text-sm text-brand-slate">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-teal flex-shrink-0"></span>
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>

          </div>
        ))}
      </div>
    </div>

  </div>
</section>
