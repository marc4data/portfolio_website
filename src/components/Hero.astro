---
import siteData from '../data/site.json';
import aboutData from '../data/about.json';
---

<section id="about" class="bg-white pt-16 pb-20 md:pt-24 md:pb-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

      <!-- Text content -->
      <div class="flex-1 text-center md:text-left">
        <!-- Eyebrow tag -->
        <div class="inline-flex items-center gap-2 bg-brand-teal/10 text-brand-teal text-xs font-semibold tracking-widest uppercase px-3 py-1 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-teal inline-block"></span>
          Open to New Opportunities · San Diego, CA
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-navy leading-tight mb-4">
          {siteData.name}
          <span class="block text-brand-slate font-normal text-2xl md:text-3xl mt-2">MBA</span>
        </h1>

        <p class="text-brand-teal font-semibold text-lg md:text-xl mb-4">
          {siteData.role}
        </p>

        <p class="text-brand-slate text-base md:text-lg leading-relaxed max-w-xl mb-8">
          {siteData.tagline}
        </p>

        <!-- Proof point strip -->
        <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-10 text-sm">
          <div class="flex flex-col items-center md:items-start">
            <span class="text-2xl font-bold text-brand-navy">20+</span>
            <span class="text-brand-slate text-xs">Years Experience</span>
          </div>
          <div class="w-px bg-gray-200 self-stretch hidden md:block"></div>
          <div class="flex flex-col items-center md:items-start">
            <span class="text-2xl font-bold text-brand-navy">6</span>
            <span class="text-brand-slate text-xs">Data Orgs Built</span>
          </div>
          <div class="w-px bg-gray-200 self-stretch hidden md:block"></div>
          <div class="flex flex-col items-center md:items-start">
            <span class="text-2xl font-bold text-brand-navy">$1M+</span>
            <span class="text-brand-slate text-xs">Cost Savings Delivered</span>
          </div>
          <div class="w-px bg-gray-200 self-stretch hidden md:block"></div>
          <div class="flex flex-col items-center md:items-start">
            <span class="text-2xl font-bold text-brand-navy">7</span>
            <span class="text-brand-slate text-xs">Certifications</span>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a
            href={siteData.resumeUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-brand-teal text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-navy transition-colors shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            View Resume
          </a>
          <a
            href={`mailto:${siteData.contactEmail}`}
            class="inline-flex items-center gap-2 border-2 border-brand-navy text-brand-navy font-semibold px-6 py-3 rounded-lg hover:bg-brand-navy hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Contact Me
          </a>
          <a
            href={aboutData.linkedin}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 border-2 border-gray-200 text-brand-slate font-semibold px-6 py-3 rounded-lg hover:border-brand-teal hover:text-brand-teal transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Headshot -->
      <div class="flex-shrink-0 relative">
        <div class="relative w-32 h-32 md:w-40 md:h-40">
          <!-- Decorative ring -->
          <div class="absolute inset-0 rounded-full border-4 border-brand-teal/20 scale-110"></div>
          <!-- Navy accent arc -->
          <div class="absolute -top-3 -right-3 w-24 h-24 rounded-full bg-brand-navy/5 border-2 border-brand-navy/10"></div>
          <img
            src={aboutData.headshot}
            alt="Marc Alexander"
            class="w-full h-full rounded-full object-cover object-top border-4 border-white shadow-xl"
          />
          <!-- Floating credential badge -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg border border-gray-100 px-4 py-2 flex items-center gap-2">
            <span class="text-2xl">🏅</span>
            <div>
              <p class="text-xs font-bold text-brand-navy leading-tight">7 Certifications</p>
              <p class="text-xs text-brand-slate leading-tight">dbt · Snowflake · Tableau</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
