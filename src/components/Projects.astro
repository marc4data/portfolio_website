---
import projectsData from '../data/projects.json';
---

<section id="projects" class="bg-brand-light py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-14 text-center">
      <p class="text-brand-teal text-sm font-semibold tracking-widest uppercase mb-2">Portfolio</p>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy">Projects</h2>
      <p class="mt-3 text-brand-slate text-base md:text-lg max-w-xl mx-auto">
        Real work, real data, real outcomes. These are all projects built in the last couple of months.
      </p>
    </div>

    <!-- Project cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projectsData.map(project => (
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow flex flex-col">

          <!-- Card header accent -->
          <div class="h-1.5 bg-gradient-to-r from-brand-teal to-brand-navy rounded-t-xl"></div>

          <div class="p-6 flex flex-col flex-1">
            <!-- Status badge -->
            <div class="mb-4">
              {project.status === 'live' ? (
                <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full border border-green-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Live Project
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 bg-brand-navy/5 text-brand-navy text-xs font-semibold px-2.5 py-1 rounded-full">
                  📋 Case Study
                </span>
              )}
            </div>

            <h3 class="text-lg font-bold text-brand-navy mb-3 leading-tight">{project.title}</h3>
            <p class="text-brand-slate text-sm leading-relaxed flex-1 mb-5">{project.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tags.map(tag => (
                <span class="bg-brand-light text-brand-slate text-xs font-medium px-2.5 py-1 rounded border border-brand-slate/10">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-3 pt-4 border-t border-gray-100 mt-auto">
              {project.github ? (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-teal hover:text-brand-navy transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                  View on GitHub
                </a>
              ) : (
                <span class="text-sm text-brand-slate/50 italic">Narrative case study — no public repo</span>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-slate hover:text-brand-teal transition-colors ml-auto"
                >
                  View Sample Report →
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- "Add projects by editing JSON" helper note -->
    <p class="text-center text-xs text-brand-slate/50 mt-8">
      New project? Add it to <code class="font-mono bg-brand-light px-1 py-0.5 rounded">src/data/projects.json</code> and push to GitHub.
    </p>

  </div>
</section>
