---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const navLinks = [
  { label: 'About',    href: '#about' },
  { label: 'Timeline', href: '#timeline' },
  { label: 'Skills',   href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact',  href: '#contact' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📊</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-white font-sans text-brand-slate">

    <!-- Nav -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="#" class="text-brand-navy font-bold text-lg tracking-tight hover:text-brand-teal transition-colors">
          Marc Alexander
        </a>
        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-8">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium text-brand-slate hover:text-brand-teal transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <!-- Resume CTA -->
        <a
          href="/marc_alexander_resume.pdf"
          target="_blank"
          rel="noopener"
          class="hidden md:inline-flex items-center gap-2 bg-brand-teal text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-navy transition-colors"
        >
          Resume
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </a>
        <!-- Mobile menu icon (hamburger, no JS needed — links scroll) -->
        <div class="md:hidden flex flex-col gap-1 cursor-pointer" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
          <span class="block w-6 h-0.5 bg-brand-navy"></span>
          <span class="block w-6 h-0.5 bg-brand-navy"></span>
          <span class="block w-6 h-0.5 bg-brand-navy"></span>
        </div>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-6 py-4">
        <ul class="flex flex-col gap-4">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium text-brand-slate hover:text-brand-teal transition-colors"
                onclick="document.getElementById('mobile-menu').classList.add('hidden')"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/marc_alexander_resume.pdf" target="_blank" class="text-sm font-semibold text-brand-teal">
              Download Resume →
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brand-navy text-white/70 py-10 mt-0">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <p>© {new Date().getFullYear()} Marc Alexander · San Diego, CA</p>
        <div class="flex items-center gap-6">
          <a href="https://linkedin.com/in/marc4data" target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>
          <a href="https://github.com/marc4data" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
          <a href="mailto:marc4data@gmail.com" class="hover:text-white transition-colors">Email</a>
        </div>
      </div>
    </footer>

  </body>
</html>
